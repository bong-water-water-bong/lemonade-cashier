# Lemonade Cashier — local configuration template.
# Copy to .env and adjust. Nothing here leaves the machine by default.

# Tax rate applied to taxable line items (decimal, e.g. 0.15 for 15%).
LC_TAX_RATE=0.15

# Where to write the append-only event log (relative paths resolve from the
# project root). Each line is one JSON event; the file is hash-chained.
LC_EVENT_LOG=data/events/cashier.jsonl

# Where to write rendered receipts (one JSON file per closed transaction).
LC_RECEIPT_DIR=data/receipts

# Lemonade Server (local). Used as a fallback parser for ambiguous attendant
# phrases only. The system runs fully offline if this is unreachable.
LC_LEMONADE_URL=http://127.0.0.1:8000
LC_LEMONADE_MODEL=Qwen3-4B-GGUF
LC_LEMONADE_TIMEOUT_SEC=2.0
LC_LEMONADE_ENABLED=false

# FastFlowLM (NPU). Same role as Lemonade — secondary parser fallback.
LC_FLM_URL=http://127.0.0.1:11434
LC_FLM_MODEL=qwen3:4b
LC_FLM_ENABLED=false

# Risk scoring thresholds. The cashier UI flags any transaction whose
# risk score exceeds the warn threshold; transactions above the block
# threshold require a supervisor PIN before closing.
LC_RISK_WARN=0.4
LC_RISK_BLOCK=0.7

# CIT (cash-in-transit). Drops above this dollar amount are required to be
# witnessed (two-person rule).
LC_CIT_TWO_PERSON_THRESHOLD=200.00
